{
  "mcpServers": {
    "screenote": {
      "type": "http",
      "url": "${SCREENOTE_URL:-https://screenote.ai}/mcp/messages"
    },
    "browser-use": {
      "type": "stdio",
      "command": "uvx",
      "args": ["--from", "browser-use[cli]", "browser-use", "--mcp"],
      "env": {
        "BROWSER_USE_HEADLESS": "${BROWSER_USE_HEADLESS:-true}"
      }
    }
  }
}
